# Drive paths to mount into the container.
# Map each path to /data/<drive_id> matching STORAGE_DRIVES in src/lib/constants.ts.
# Adjust the number of drives and paths to match your setup.
#
# Windows example:
DRIVE_1_PATH=E:\
DRIVE_2_PATH=F:\
DRIVE_3_PATH=G:\
DRIVE_4_PATH=H:\
#
# Linux/Mac example:
# DRIVE_1_PATH=/mnt/hdd1
# DRIVE_2_PATH=/mnt/hdd2
# DRIVE_3_PATH=/mnt/ssd1
# DRIVE_4_PATH=/mnt/ssd2

# Authentication
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate hash:   node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
JWT_SECRET=your-secret-key-here
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=$2b$10$your-bcrypt-hash-here
