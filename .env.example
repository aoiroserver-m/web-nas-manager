# Docker Compose volume mapping
# Windows drive paths for NAS storage
HDD_001_PATH=E:\
HDD_002_PATH=F:\
SSD_001_PATH=G:\
SSD_002_PATH=H:\

# Authentication
# Generate password hash: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
JWT_SECRET=your-secret-key-here
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=$2b$10$your-bcrypt-hash-here
